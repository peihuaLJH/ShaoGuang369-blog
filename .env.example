# 后端运行时环境变量「清单」。
# 用法：在每台服务器上复制为 .env 并填入真实值。
# 注意：.env 被 .gitignore 忽略，不会随 git 部署，所以每台服务器都要手动配置一次。

# ===== 数据库（必填）=====
# 若 MongoDB 开启了鉴权，URI 里必须带 用户名:密码 和 authSource，否则查询会报 "requires authentication"
MONGODB_URI=mongodb://用户名:密码@127.0.0.1:27017/blog?authSource=admin

# ===== 登录鉴权（必填）=====
JWT_SECRET=换成一段足够长的随机字符串

# ===== 服务端口（可选，默认 5000）=====
PORT=5000

# ===== 邮件通知 SMTP（必填，否则"发布文章→通知订阅者"会静默失败发不出邮件）=====
# QQ 邮箱：登录网页版邮箱 → 设置 → 账号 → 开启 POP3/SMTP 服务 → 拿到「授权码」
# SMTP_PASS 必须填这个 16 位授权码，不是 QQ 登录密码！
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ邮箱@qq.com
SMTP_PASS=你的16位授权码

# 邮件里"阅读全文"按钮指向的站点正式域名（不要用 localhost，否则订阅者点开打不开）
FRONTEND_URL=https://shaoguang369.top
